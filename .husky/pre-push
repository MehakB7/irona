#!/bin/sh

ENV_EXAMPLE=".env.example"
ENV_LOCAL=".env"

if [ ! -f "$ENV_LOCAL" ]; then
  echo "Warning: $ENV_LOCAL not found, skipping env variable count check."
  exit 0
fi

count_vars() {
  grep -cE '^[^#[:space:]][^=]*=' "$1" 2>/dev/null || echo 0
}

example_count=$(count_vars "$ENV_EXAMPLE")
local_count=$(count_vars "$ENV_LOCAL")

if [ "$example_count" -ne "$local_count" ]; then
  echo ""
  echo "Pre-push failed: env variable count mismatch"
  echo "  .env.example : $example_count variables"
  echo "  .env.local   : $local_count variables"
  echo ""
  echo "Update .env.example to match all variables in .env (leave values empty)."
  echo ""
  exit 1
fi

echo "env check passed: $example_count variables in both .env.example and .env"
